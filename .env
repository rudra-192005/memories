# Memory Site Configuration
# Change these values for production!

# Secret key for sessions - CHANGE THIS!
SECRET_KEY=your-super-secret-key-change-this-2026

# Database URL (SQLite for development)
DATABASE_URL=sqlite:///memories.db

# Flask environment (development/production)
FLASK_ENV=development
FLASK_DEBUG=1

# Upload settings
MAX_CONTENT_LENGTH=524288000  # 500MB in bytes

# Admin email (for notifications)
ADMIN_EMAIL=admin@yourdomain.com

# Site settings
SITE_NAME="My Private Memories"
SITE_URL=http://localhost:5000
